# ════════════════════════════════════════════════════════════
# HSIOS Website — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ════════════════════════════════════════════════════════════

# ── SMTP Email (Hostinger) ────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@hsios.in
SMTP_PASS=YOUR_EMAIL_PASSWORD_HERE

# Comma-separated list of emails to notify on new enquiries
NOTIFY_EMAILS=hello@hsios.in,mayureshmhatre49@gmail.com,nishant.mhatre@mail.com

# ── Analytics ─────────────────────────────────────────────
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# ── Site URL ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.hsios.in

# ── Optional: reCAPTCHA v3 ─────────────────────────────────
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# ── Supabase ───────────────────────────────────────────────
# Find these in Supabase → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NEVER expose publicly

# ── Referral Admin Panel ───────────────────────────────────
# Password for /admin/login
ADMIN_PASSWORD=choose-a-strong-password
# Secret used to sign admin session cookies (run: openssl rand -hex 32)
ADMIN_SECRET=your-32-char-secret-here
